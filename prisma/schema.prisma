generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum GenerationMode {
  CHAT
  IMAGE
}

model User {
  id                    String        @id @default(cuid())
  email                 String        @unique
  name                  String
  passwordHash          String
  role                  Role          @default(USER)
  userGroup             String        @default("NORMAL")
  active                Boolean       @default(true)
  emailVerified         Boolean       @default(true)
  aiStylePrompt         String        @default("")
  monthlyTokenLimit     Int           @default(200000)
  monthlyMessageLimit   Int           @default(500)
  monthlyCostLimitCents Int           @default(0)
  aiPointsBalanceCents  Float         @default(0)
  quotaResetAt          DateTime      @default(now())
  quotaNextResetAt      DateTime      @default(now())
  quotaSystemMigratedAt DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  conversations         Conversation[]
  conversationShares    ConversationShare[]
  usageRecords          UsageRecord[]
  attachments           Attachment[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens   PasswordResetToken[]
  sessions              UserSession[]
  authEvents            AuthEvent[]
  paymentOrders        PaymentOrder[]
  apiKeys              UserApiKey[]
  memories             UserMemory[]
  projects             UserProject[]
}

model UserMemory {
  id              String    @id @default(cuid())
  userId          String
  projectId       String?
  content         String
  source          String    @default("chat")
  sourceMessageId String?
  archivedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  project         UserProject? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([userId, updatedAt])
  @@index([userId, source])
  @@index([userId, archivedAt, updatedAt])
  @@index([userId, projectId, archivedAt, updatedAt])
}

model UserProject {
  id            String   @id @default(cuid())
  userId        String
  name          String
  instructions  String   @default("")
  memoryScope   String   @default("account")
  defaultModel   String   @default("")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  memories      UserMemory[]
  conversations Conversation[]
  attachments   Attachment[]

  @@index([userId, updatedAt])
}

model UserApiKey {
  id          String    @id @default(cuid())
  userId      String
  name        String
  keyHash     String    @unique
  keyEncrypted String?
  keyPrefix   String
  active      Boolean   @default(true)
  lastUsedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([keyPrefix])
}

model PaymentOrder {
  id              String    @id @default(cuid())
  userId          String
  provider        String    @default("easypay")
  method          String
  status          String    @default("PENDING")
  outTradeNo      String    @unique
  providerTradeNo String?
  subject         String
  amountCents     Int
  balanceCents    Int       @default(0)
  metadataJson    String    @default("{}")
  paidAt          DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([expiresAt])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([expiresAt])
}

model UserSession {
  id            String    @id @default(cuid())
  userId        String
  userAgent     String    @default("")
  deviceLabel   String    @default("")
  createdAt     DateTime  @default(now())
  lastSeenAt    DateTime  @default(now())
  expiresAt     DateTime
  revokedAt     DateTime?
  revokedReason String    @default("")
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, lastSeenAt])
  @@index([userId, revokedAt, expiresAt])
  @@index([expiresAt])
}

model AuthEvent {
  id        String   @id @default(cuid())
  userId    String?
  email     String   @default("")
  type      String
  success   Boolean  @default(false)
  message   String   @default("")
  userAgent String   @default("")
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([email, createdAt])
  @@index([type, createdAt])
}

model Conversation {
  id        String         @id @default(cuid())
  userId    String
  projectId String?
  title     String         @default("New chat")
  model     String
  mode      GenerationMode @default(CHAT)
  pinned    Boolean        @default(false)
  archivedAt DateTime?
  contextSummaryMessageCount Int @default(0)
  contextSummaryTokens Int @default(0)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   UserProject?   @relation(fields: [projectId], references: [id], onDelete: SetNull)
  messages  Message[]
  usage     UsageRecord[]
  attachments Attachment[]
  share     ConversationShare?

  @@index([userId, updatedAt])
  @@index([userId, pinned, updatedAt])
  @@index([userId, archivedAt, updatedAt])
  @@index([userId, projectId, updatedAt])
}

model ConversationShare {
  id             String       @id @default(cuid())
  token          String       @unique
  conversationId String       @unique
  userId         String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model Message {
  id                 String         @id @default(cuid())
  conversationId     String
  role               MessageRole
  content            String
  reasoningContent   String?
  imageUrl           String?
  webSourcesJson     String         @default("[]")
  generationStatus   String         @default("done")
  streamStatus       String?
  toolEventsJson     String         @default("[]")
  processStartedAt   DateTime?
  processFinishedAt  DateTime?
  model              String?
  mode               GenerationMode @default(CHAT)
  promptTokens       Int            @default(0)
  completionTokens   Int            @default(0)
  totalTokens        Int            @default(0)
  cachedPromptTokens Int            @default(0)
  reasoningTokens    Int            @default(0)
  usageSource        String         @default("estimated")
  upstreamUsageJson  String?
  estimatedCostCents Float          @default(0)
  createdAt          DateTime       @default(now())
  conversation       Conversation   @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  attachments        Attachment[]

  @@index([conversationId, createdAt])
}

model Attachment {
  id             String        @id @default(cuid())
  userId         String
  projectId      String?
  conversationId String?
  messageId      String?
  kind           String
  originalName   String
  mimeType       String
  sizeBytes      Int
  storagePath    String
  extractedText  String?
  temporary      Boolean       @default(false)
  createdAt      DateTime      @default(now())
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  project        UserProject?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  message        Message?      @relation(fields: [messageId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([userId, temporary, createdAt])
  @@index([userId, projectId, createdAt])
  @@index([conversationId])
  @@index([messageId])
}

model UsageRecord {
  id                 String         @id @default(cuid())
  userId             String
  conversationId     String?
  messageId          String?
  model              String
  mode               GenerationMode
  promptTokens       Int            @default(0)
  completionTokens   Int            @default(0)
  totalTokens        Int            @default(0)
  cachedPromptTokens Int            @default(0)
  reasoningTokens    Int            @default(0)
  usageSource        String         @default("estimated")
  upstreamUsageJson  String?
  estimatedCostCents Float          @default(0)
  subscriptionCostCents Float       @default(0)
  aiPointsCostCents  Float          @default(0)
  quotaSource        String         @default("MONTHLY_SUBSCRIPTION")
  endpoint           String         @default("")
  requestKind        String         @default("")
  billingMode        String         @default("按量")
  reasoningEffort    String         @default("")
  firstTokenLatencyMs Int?
  durationMs         Int?
  userAgent          String         @default("")
  createdAt          DateTime       @default(now())
  user               User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation       Conversation?  @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([conversationId])
  @@index([usageSource, createdAt])
  @@index([model, createdAt])
}

model AiSettings {
  id                    String   @id @default("default")
  siteName              String   @default("Team AI Gateway")
  siteUrl               String   @default("")
  apiBaseUrl            String   @default("https://api.openai.com/v1")
  apiKey                String?
  orgId                 String?
  gpt54ProApiBaseUrl    String   @default("")
  gpt54ProApiKey        String?
  gpt54ProOrgId         String?
  mockResponses         Boolean  @default(false)
  chatModelMapJson      String   @default("{\"GPT-5.6-Sol\":\"gpt-5.6-sol\",\"GPT-5.6-Sol-Ultra\":\"gpt-5.6-sol-ultra\",\"GPT-5.6-Terra\":\"gpt-5.6-terra\",\"GPT-5.6-Luna\":\"gpt-5.6-luna\",\"GPT-5.5\":\"gpt-5.5\",\"GPT-5.4\":\"gpt-5.4\",\"GPT-5.4-Pro\":\"gpt-5.4-pro\",\"GPT-5.4-Mini\":\"gpt-5.4-mini\",\"GPT-5.3-Codex-Spark\":\"gpt-5.3-codex-spark\"}")
  chatModelDisplayJson  String   @default("{}")
  availableModelsJson   String   @default("[]")
  enabledChatModelsJson String   @default("[]")
  imageModelId          String   @default("image2")
  defaultReasoningEffort String  @default("medium")
  reasoningParamMode    String   @default("chat")
  systemPromptMode      String   @default("default")
  customSystemPrompt    String   @default("")
  modelSystemPromptsJson String  @default("{}")
  codeInterpreterEnabled Boolean @default(false)
  codeInterpreterSandbox String  @default("docker")
  codeInterpreterAllowPackageInstall Boolean @default(false)
  codeInterpreterPipIndexUrl String @default("https://pypi.org/simple")
  contextCompressionEnabled Boolean @default(false)
  contextCompressionThresholdPercent Int @default(70)
  longContextThresholdTokens Int @default(0)
  webSearchEnabled    Boolean @default(false)
  webSearchProvider   String  @default("duckduckgo")
  webSearchMaxResults Int     @default(5)
  registrationEnabled Boolean @default(false)
  registrationRequireEmailVerification Boolean @default(false)
  registrationDefaultCostLimitCents Int @default(5000)
  smtpEnabled         Boolean @default(false)
  smtpHost            String  @default("")
  smtpPort            Int     @default(587)
  smtpUsername        String  @default("")
  smtpPassword        String?
  smtpFromEmail       String  @default("")
  smtpFromName        String  @default("")
  smtpSecure          Boolean @default(false)
  smtpStartTls        Boolean @default(true)
  easyPayEnabled      Boolean @default(false)
  easyPayAllowRefund  Boolean @default(false)
  easyPayDisplayMode  String  @default("qrcode")
  easyPayMethodsJson  String  @default("[\"alipay\",\"wxpay\"]")
  easyPayBalanceCentsPerYuan Int @default(100)
  easyPayAmountTiersJson String @default("[]")
  easyPayPid          String  @default("")
  easyPayKey          String?
  easyPayApiBaseUrl   String  @default("")
  easyPayAlipayChannelId String @default("")
  easyPayWxpayChannelId String @default("")
  updatedAt             DateTime @updatedAt
}
