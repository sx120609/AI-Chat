generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum GenerationMode {
  CHAT
  IMAGE
}

model User {
  id                    String        @id @default(cuid())
  email                 String        @unique
  name                  String
  passwordHash          String
  role                  Role          @default(USER)
  userGroup             String        @default("NORMAL")
  active                Boolean       @default(true)
  emailVerified         Boolean       @default(true)
  aiStylePrompt         String        @default("")
  monthlyTokenLimit     Int           @default(200000)
  monthlyMessageLimit   Int           @default(500)
  monthlyCostLimitCents Int           @default(5000)
  quotaResetAt          DateTime      @default(now())
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  conversations         Conversation[]
  conversationShares    ConversationShare[]
  usageRecords          UsageRecord[]
  attachments           Attachment[]
  emailVerificationTokens EmailVerificationToken[]
  paymentOrders        PaymentOrder[]
  apiKeys              UserApiKey[]
  memories             UserMemory[]
  tasks                UserTask[]
  projects             UserProject[]
  notifications        UserNotification[]
  appConnectors        UserAppConnector[]
}

model UserMemory {
  id              String    @id @default(cuid())
  userId          String
  projectId       String?
  content         String
  source          String    @default("chat")
  sourceMessageId String?
  archivedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  project         UserProject? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([userId, updatedAt])
  @@index([userId, source])
  @@index([userId, archivedAt, updatedAt])
  @@index([userId, projectId, archivedAt, updatedAt])
}

model UserTask {
  id          String    @id @default(cuid())
  userId      String
  projectId   String?
  title       String
  prompt      String
  schedule    String    @default("once")
  timezone    String    @default("Asia/Hong_Kong")
  nextRunAt   DateTime?
  enabled     Boolean   @default(true)
  lastRunAt   DateTime?
  lastStatus  String    @default("pending")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  project     UserProject? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([userId, enabled, nextRunAt])
  @@index([userId, projectId, enabled, nextRunAt])
  @@index([userId, createdAt])
}

model UserProject {
  id            String   @id @default(cuid())
  userId        String
  name          String
  instructions  String   @default("")
  memoryScope   String   @default("account")
  defaultModel   String   @default("")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  memories      UserMemory[]
  conversations Conversation[]
  attachments   Attachment[]
  tasks         UserTask[]

  @@index([userId, updatedAt])
}

model UserApiKey {
  id          String    @id @default(cuid())
  userId      String
  name        String
  keyHash     String    @unique
  keyEncrypted String?
  keyPrefix   String
  active      Boolean   @default(true)
  lastUsedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([keyPrefix])
}

model UserNotification {
  id           String    @id @default(cuid())
  userId       String
  type         String
  title        String
  body         String    @default("")
  metadataJson String    @default("{}")
  readAt       DateTime?
  emailedAt    DateTime?
  createdAt    DateTime  @default(now())
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt])
  @@index([userId, type, createdAt])
}

model UserAppConnector {
  id           String    @id @default(cuid())
  userId       String
  provider     String
  enabled      Boolean   @default(false)
  status       String    @default("disconnected")
  metadataJson String    @default("{}")
  authorizedAt DateTime?
  revokedAt    DateTime?
  lastUsedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@index([userId, updatedAt])
}

model PaymentOrder {
  id              String    @id @default(cuid())
  userId          String
  provider        String    @default("easypay")
  method          String
  status          String    @default("PENDING")
  outTradeNo      String    @unique
  providerTradeNo String?
  subject         String
  amountCents     Int
  balanceCents    Int       @default(0)
  metadataJson    String    @default("{}")
  paidAt          DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([expiresAt])
}

model Conversation {
  id        String         @id @default(cuid())
  userId    String
  projectId String?
  title     String         @default("New chat")
  model     String
  mode      GenerationMode @default(CHAT)
  pinned    Boolean        @default(false)
  archivedAt DateTime?
  contextSummary String?
  contextSummaryUntilMessageId String?
  contextSummaryUntilCreatedAt DateTime?
  contextSummaryMessageCount Int @default(0)
  contextSummaryTokens Int @default(0)
  contextSummaryUpdatedAt DateTime?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   UserProject?   @relation(fields: [projectId], references: [id], onDelete: SetNull)
  messages  Message[]
  usage     UsageRecord[]
  attachments Attachment[]
  share     ConversationShare?

  @@index([userId, updatedAt])
  @@index([userId, pinned, updatedAt])
  @@index([userId, archivedAt, updatedAt])
  @@index([userId, projectId, updatedAt])
}

model ConversationShare {
  id             String       @id @default(cuid())
  token          String       @unique
  conversationId String       @unique
  userId         String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model Message {
  id                 String         @id @default(cuid())
  conversationId     String
  role               MessageRole
  content            String
  reasoningContent   String?
  imageUrl           String?
  webSourcesJson     String         @default("[]")
  generationStatus   String         @default("done")
  streamStatus       String?
  toolEventsJson     String         @default("[]")
  processStartedAt   DateTime?
  processFinishedAt  DateTime?
  model              String?
  mode               GenerationMode @default(CHAT)
  promptTokens       Int            @default(0)
  completionTokens   Int            @default(0)
  totalTokens        Int            @default(0)
  cachedPromptTokens Int            @default(0)
  reasoningTokens    Int            @default(0)
  usageSource        String         @default("estimated")
  upstreamUsageJson  String?
  estimatedCostCents Float          @default(0)
  createdAt          DateTime       @default(now())
  conversation       Conversation   @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  attachments        Attachment[]

  @@index([conversationId, createdAt])
}

model Attachment {
  id             String        @id @default(cuid())
  userId         String
  projectId      String?
  conversationId String?
  messageId      String?
  kind           String
  originalName   String
  mimeType       String
  sizeBytes      Int
  storagePath    String
  extractedText  String?
  temporary      Boolean       @default(false)
  createdAt      DateTime      @default(now())
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  project        UserProject?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  message        Message?      @relation(fields: [messageId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([userId, temporary, createdAt])
  @@index([userId, projectId, createdAt])
  @@index([conversationId])
  @@index([messageId])
}

model UsageRecord {
  id                 String         @id @default(cuid())
  userId             String
  conversationId     String?
  messageId          String?
  model              String
  mode               GenerationMode
  promptTokens       Int            @default(0)
  completionTokens   Int            @default(0)
  totalTokens        Int            @default(0)
  cachedPromptTokens Int            @default(0)
  reasoningTokens    Int            @default(0)
  usageSource        String         @default("estimated")
  upstreamUsageJson  String?
  estimatedCostCents Float          @default(0)
  endpoint           String         @default("")
  requestKind        String         @default("")
  billingMode        String         @default("按量")
  reasoningEffort    String         @default("")
  firstTokenLatencyMs Int?
  durationMs         Int?
  userAgent          String         @default("")
  createdAt          DateTime       @default(now())
  user               User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation       Conversation?  @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([conversationId])
  @@index([usageSource, createdAt])
  @@index([model, createdAt])
}

model AiSettings {
  id                    String   @id @default("default")
  siteName              String   @default("Team AI Gateway")
  siteUrl               String   @default("")
  apiBaseUrl            String   @default("https://api.openai.com/v1")
  apiKey                String?
  orgId                 String?
  mockResponses         Boolean  @default(false)
  chatModelMapJson      String   @default("{\"GPT-5.5\":\"gpt-5.5\",\"GPT-5.5-1M\":\"gpt-5.5\",\"GPT-5.4\":\"gpt-5.4\",\"GPT-5.4-Mini\":\"gpt-5.4-mini\",\"GPT-5.3-Codex-Spark\":\"gpt-5.3-codex-spark\"}")
  chatModelDisplayJson  String   @default("{}")
  availableModelsJson   String   @default("[]")
  enabledChatModelsJson String   @default("[]")
  imageModelId          String   @default("image2")
  defaultReasoningEffort String  @default("medium")
  reasoningParamMode    String   @default("chat")
  contextCompressionEnabled Boolean @default(true)
  contextCompressionThresholdPercent Int @default(78)
  longContextThresholdTokens Int @default(200000)
  systemPromptMode      String   @default("default")
  customSystemPrompt    String   @default("")
  modelSystemPromptsJson String  @default("{}")
  codeInterpreterEnabled Boolean @default(false)
  codeInterpreterSandbox String  @default("docker")
  codeInterpreterAllowPackageInstall Boolean @default(false)
  codeInterpreterPipIndexUrl String @default("https://pypi.org/simple")
  webSearchEnabled    Boolean @default(false)
  webSearchProvider   String  @default("duckduckgo")
  webSearchMaxResults Int     @default(5)
  registrationEnabled Boolean @default(false)
  registrationRequireEmailVerification Boolean @default(false)
  registrationDefaultCostLimitCents Int @default(5000)
  smtpEnabled         Boolean @default(false)
  smtpHost            String  @default("")
  smtpPort            Int     @default(587)
  smtpUsername        String  @default("")
  smtpPassword        String?
  smtpFromEmail       String  @default("")
  smtpFromName        String  @default("")
  smtpSecure          Boolean @default(false)
  smtpStartTls        Boolean @default(true)
  easyPayEnabled      Boolean @default(false)
  easyPayAllowRefund  Boolean @default(false)
  easyPayDisplayMode  String  @default("qrcode")
  easyPayMethodsJson  String  @default("[\"alipay\",\"wxpay\"]")
  easyPayBalanceCentsPerYuan Int @default(100)
  easyPayPid          String  @default("")
  easyPayKey          String?
  easyPayApiBaseUrl   String  @default("")
  easyPayAlipayChannelId String @default("")
  easyPayWxpayChannelId String @default("")
  updatedAt             DateTime @updatedAt
}
