# Database
DB_NAME="team_ai_gateway"
DB_USER="team_ai_gateway"
DB_PASSWORD="change-me"
DATABASE_URL="postgresql://team_ai_gateway:change-me@127.0.0.1:5432/team_ai_gateway?schema=public"
REDIS_URL="redis://127.0.0.1:6379"
CACHE_ENABLED="true"

# Auth cookie signing secret. Use a long random value in production.
AUTH_SECRET="change-me-to-a-long-random-secret"

# Optional bootstrap/fallback upstream AI API.
# After login, set or replace these from 管理后台 -> API 设置.
AI_API_KEY=""
AI_API_BASE_URL="https://api.openai.com/v1"
AI_GPT54_PRO_API_KEY=""
AI_GPT54_PRO_API_BASE_URL=""
AI_GPT54_PRO_ORG_ID=""

# Optional initial site settings. Admin dashboard can replace these later.
SITE_NAME="Team AI Gateway"
SITE_URL=""

# Optional upstream headers
# AI_ORG_ID=""

# Local development helper. Set to true to run without a real API key.
AI_MOCK_RESPONSES="false"

# Optional code-interpreter style file analysis.
# Disabled by default. When enabled, generated Python must run in a Docker sandbox.
CODE_INTERPRETER_ENABLED="false"
CODE_INTERPRETER_SANDBOX="docker"
CODE_INTERPRETER_DOCKER_IMAGE="python:3.12-slim"
CODE_INTERPRETER_ALLOW_PACKAGE_INSTALL="false"
CODE_INTERPRETER_PIP_INDEX_URL="https://pypi.org/simple"
CODE_INTERPRETER_TIMEOUT_MS="45000"
CODE_INTERPRETER_PACKAGE_CACHE="true"
CODE_INTERPRETER_CACHE_DIR=".cache/code-interpreter"
CODE_INTERPRETER_PACKAGE_INSTALL_TIMEOUT_MS="120000"
CODE_INTERPRETER_DOCKER_MEMORY="768m"
CODE_INTERPRETER_DOCKER_CPUS="1"

# Optional server-side web search. Search runs on the backend, not in user browsers.
WEB_SEARCH_ENABLED="false"
WEB_SEARCH_PROVIDER="duckduckgo"
WEB_SEARCH_MAX_RESULTS="5"

# Optional public registration and email verification bootstrap.
REGISTRATION_ENABLED="false"
REGISTRATION_REQUIRE_EMAIL_VERIFICATION="false"
REGISTRATION_DEFAULT_COST_LIMIT_CENTS="5000"

# Optional SMTP mail service. STARTTLS is enabled by default for port 587 style servers.
SMTP_ENABLED="false"
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USERNAME=""
SMTP_PASSWORD=""
SMTP_FROM_EMAIL=""
SMTP_FROM_NAME=""
SMTP_SECURE="false"
SMTP_STARTTLS="true"

# Optional EasyPay recharge provider.
EASYPAY_ENABLED="false"
EASYPAY_ALLOW_REFUND="false"
EASYPAY_DISPLAY_MODE="qrcode"
EASYPAY_METHODS_JSON="[\"alipay\",\"wxpay\"]"
EASYPAY_BALANCE_CENTS_PER_YUAN="100"
EASYPAY_PID=""
EASYPAY_KEY=""
EASYPAY_API_BASE_URL=""
EASYPAY_ALIPAY_CHANNEL_ID=""
EASYPAY_WXPAY_CHANNEL_ID=""

# Optional Coding Plan bootstrap. The plan remains off unless explicitly enabled.
CODING_PLAN_ENABLED="false"
CODING_PLAN_NAME="Coding Plan"
CODING_PLAN_DESCRIPTION="面向编码任务的月度额度套餐"
CODING_PLAN_PRICE_CENTS="1990"
CODING_PLAN_MONTHLY_COST_LIMIT_CENTS="1000"
CODING_PLAN_PERSONAL_API_ENABLED="true"

# Initial admin created by npm run db:seed
ADMIN_EMAIL=""
ADMIN_PASSWORD=""
ADMIN_NAME="管理员"
